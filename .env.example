# ─────────────────────────────────────────────────────────────
# All variables are optional — the app runs and builds without them.
# Features light up automatically when the relevant keys are present.
# ─────────────────────────────────────────────────────────────

# GitHub — enables the live commit-activity band on the Home page.
# A classic/fine-grained token with public read access is enough.
GITHUB_TOKEN=""

# Firebase Cloud Messaging (push notifications) — client config.
# When set, the "Enable notifications" control appears in the footer.
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=""
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""
NEXT_PUBLIC_FIREBASE_VAPID_KEY=""
